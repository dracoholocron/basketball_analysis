# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=basketball
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=basketball

# ── Redis ──────────────────────────────────────────────────────────────────────
# (no creds needed for dev, but add requirepass in prod)

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_STRONG_SECRET

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com

# ── Caddy ──────────────────────────────────────────────────────────────────────
DOMAIN=your-domain.com
